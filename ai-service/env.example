# ai-service/.env.example
#
# Copie para .env e preencha os valores reais. NUNCA commite o .env
# (deve estar no .gitignore).

# --- Supabase (obrigatório) ---
# Encontre em: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Use a "service_role" key (não a "anon" key) — o serviço de IA roda no
# backend e precisa de permissão para escrever na tabela pet_embeddings.
SUPABASE_SERVICE_ROLE_KEY=

# --- CLIP (opcional — valores abaixo já são o padrão em app/clip/model.py) ---
# CLIP_MODEL_NAME=ViT-B-32
# CLIP_PRETRAINED=laion2b_s34b_b79k
# CLIP_DEVICE=            # deixe vazio para seleção automática (cuda > mps > cpu)

# --- Florence-2 (opcional — valores abaixo já são o padrão em app/florence/model.py) ---
# FLORENCE_MODEL_NAME=microsoft/Florence-2-base
# FLORENCE_DEVICE=
# FLORENCE_ATTN_IMPLEMENTATION=eager
